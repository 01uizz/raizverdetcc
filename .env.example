# Copie para .env.local e preencha. NÃO versione o .env.local.
# Chaves do Supabase (a anon key é pública por natureza; a service_role NUNCA vai pro front)
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key

# URL pública do site (usada em e-mails de redefinição de senha quando renderizado no servidor)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Dados PIX da ONG (pessoa jurídica). Mantidos fora do código para troca sem redeploy.
NEXT_PUBLIC_PIX_KEY=00000000000000
NEXT_PUBLIC_PIX_RECEIVER=ASSOCIACAO AMIGOS DE IRACAMBI
NEXT_PUBLIC_PIX_CITY=ROSARIO DA LIMEIRA
